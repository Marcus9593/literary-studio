# Literary Studio Environment Configuration
# Copy this file to .env and modify as needed

# === Security (REQUIRED for production) ===
# ⚠️  JWT 密钥：生产环境必须设置！
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# STUDIO_JWT_SECRET=your_random_secret_here

# === Admin Account ===
# ⚠️  管理员密码：生产环境必须修改默认密码！
# STUDIO_ADMIN_USER=admin
# STUDIO_ADMIN_PASSWORD=your_secure_password

# === Server ===
# PORT=8765
# STUDIO_HOST=127.0.0.1

# === CORS ===
# STUDIO_CORS_ORIGIN=https://your-domain.com

# === Registration ===
# STUDIO_ALLOW_REGISTER=1

# === Production Mode ===
# STUDIO_PRODUCTION=1

# === Python (for document conversion) ===
# PYTHON=python3
# LITERARY_WRITER_ROOT=/path/to/literary-writer
