{
  "name": "literary-studio",
  "private": true,
  "version": "2.6.0",
  "description": "文匠 Studio — cross-platform literary writing workspace",
  "main": "electron/main.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "node scripts/start.mjs",
    "build": "node scripts/build.mjs",
    "sync:skill": "node scripts/sync-literary-writer.mjs",
    "backend": "npm run start --prefix backend-node",
    "frontend:dev": "npm run dev --prefix frontend",
    "docker:release": "node scripts/release-docker.mjs",
    "docker:release:slim": "node scripts/release-docker.mjs --target runtime-slim --tags slim",
    "electron:dev": "electron .",
    "electron:bundle": "node scripts/bundle-deps.mjs",
    "electron:icons": "python3 scripts/build-app-icon.py",
    "electron:validate-vendor": "node scripts/validate-electron-vendor.mjs",
    "electron:validate-packaged": "node scripts/validate-electron-packaged.mjs",
    "clean:test-data": "node scripts/clean-test-data.mjs",
    "clean:test-data:all": "node scripts/clean-test-data.mjs --appdata",
    "electron:clean": "node scripts/clean-pack-environment.mjs",
    "electron:clean:mac": "node scripts/clean-pack-environment.mjs --platform mac",
    "electron:clean:win": "node scripts/clean-pack-environment.mjs --platform win",
    "electron:clean:linux": "node scripts/clean-pack-environment.mjs --platform linux",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major",
    "electron:build": "node scripts/build-electron.mjs",
    "electron:build:mac": "node scripts/build-electron.mjs --mac",
    "electron:build:win": "node scripts/build-electron.mjs --win",
    "electron:build:linux": "node scripts/build-electron.mjs --linux",
    "electron:build:arm64": "node scripts/build-electron.mjs --mac --arm64",
    "electron:build:x64": "node scripts/build-electron.mjs --mac --x64",
    "frontend:build": "npm run build --prefix frontend"
  },
  "build": {
    "appId": "com.literary-studio.app",
    "productName": "文匠 Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "backend-node/**/*",
      "!backend-node/node_modules/.cache/**",
      "!backend-node/data/**",
      "frontend/dist/**/*",
      "electron/**/*",
      "!electron/vendor/**",
      "package.json"
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/@lancedb/**/*",
      "backend-node/node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "skills",
        "to": "skills",
        "filter": ["**/*"]
      },
      {
        "from": "electron/vendor",
        "to": "vendor",
        "filter": ["**/*"]
      },
      {
        "from": "backend",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "electron/icons/icon.icns",
      "category": "public.app-category.productivity"
    },
    "dmg": {
      "title": "文匠 Studio",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "electron/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "include": "electron/installer.nsh",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "文匠 Studio"
    },
    "linux": {
      "target": [
        {
          "target": "rpm",
          "arch": ["x64"]
        }
      ],
      "category": "Office",
      "synopsis": "文匠 Studio — AI 写作工作台",
      "description": "编剧级 AI 创作工作台，面向网文、长篇叙事与剧本写作。",
      "maintainer": "Literary Studio"
    },
    "rpm": {
      "depends": []
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "35.7.5",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {}
}
