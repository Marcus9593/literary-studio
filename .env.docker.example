# Copy to .env.docker before running: cp .env.docker.example .env.docker
# Used by docker-compose.yml

# === Required for production ===
STUDIO_PRODUCTION=1
STUDIO_JWT_SECRET=change_me_to_a_random_32_char_secret
STUDIO_ADMIN_PASSWORD=change_me_strong_password

# === Admin ===
STUDIO_ADMIN_USER=admin

# === Server (host port mapping uses PORT below) ===
PORT=8765

# === Security ===
STUDIO_ALLOW_REGISTER=0
# Comma-separated origins when accessing Studio from another domain:
# STUDIO_CORS_ORIGIN=https://studio.example.com

# === Optional ===
# NODE_ENV=production
