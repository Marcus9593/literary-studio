{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://literary-studio.local/schemas/measurement-review-latest.json",
  "title": "measurement/review/latest.json",
  "type": "object",
  "required": ["schema", "project_id", "checks", "hints"],
  "properties": {
    "schema": { "const": "measurement_review_latest" },
    "project_id": { "type": "string" },
    "manuscript_words": { "type": "integer", "minimum": 0 },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "status"],
        "properties": {
          "key": { "type": "string" },
          "status": { "enum": ["pending", "done"] },
          "score": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
          "updated_at": { "type": ["string", "null"], "format": "date-time" }
        }
      }
    },
    "hints": { "type": "array", "items": { "type": "string" } },
    "updated_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
